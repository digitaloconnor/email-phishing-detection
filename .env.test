# Email Phishing Detection — Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to version control

# ─── Microsoft / Outlook ──────────────────────────────────────
# Azure AD App Client ID (from Azure Portal > App Registrations)
MICROSOFT_CLIENT_ID=

# Azure AD App Client Secret
MICROSOFT_CLIENT_SECRET=

# Azure AD Tenant ID
MICROSOFT_TENANT_ID=

# Mailbox to monitor (UPN or shared mailbox address)
OUTLOOK_MAILBOX=

# ─── OpenAI ───────────────────────────────────────────────────
# OpenAI API key — found at platform.openai.com/api-keys
OPENAI_API_KEY=

# ─── Slack ────────────────────────────────────────────────────
# Slack Bot OAuth token (xoxb-...)
SLACK_BOT_TOKEN=

# Slack channel ID for security alerts (not the channel name)
SLACK_SECURITY_CHANNEL_ID=
